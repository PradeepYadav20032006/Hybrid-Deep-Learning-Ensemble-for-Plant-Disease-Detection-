def build_noisy_transforms(noise_type: str = "gaussian"):
    """
    Build transforms that introduce controlled degradation to test robustness.
    """
    class AddGaussianNoise:
        def __init__(self, mean=0.0, std=0.1):
            self.mean = mean
            self.std = std
        def __call__(self, tensor):
            noise = torch.randn_like(tensor) * self.std + self.mean
            return torch.clamp(tensor + noise, 0.0, 1.0)
        def __repr__(self):
            return f"AddGaussianNoise(mean={self.mean}, std={self.std})"
    class AddBlur:
        def __init__(self, kernel_size=5):
            self.kernel_size = kernel_size
        def __call__(self, tensor):
            return transforms.GaussianBlur(self.kernel_size, sigma=(0.5, 2.0))(tensor)
        def __repr__(self):
            return f"AddBlur(kernel={self.kernel_size})"
    noise_transforms = {
        "gaussian": transforms.Compose([
            transforms.Resize((CFG.IMAGE_SIZE, CFG.IMAGE_SIZE)),
            transforms.ToTensor(),
            AddGaussianNoise(std=0.15),
            transforms.Normalize(mean=IMAGENET_MEAN, std=IMAGENET_STD),
        ]),
        "blur": transforms.Compose([
            transforms.Resize((CFG.IMAGE_SIZE, CFG.IMAGE_SIZE)),
            transforms.ToTensor(),
            AddBlur(kernel_size=7),
            transforms.Normalize(mean=IMAGENET_MEAN, std=IMAGENET_STD),
        ]),
        "combined": transforms.Compose([
            transforms.Resize((CFG.IMAGE_SIZE, CFG.IMAGE_SIZE)),
            transforms.ColorJitter(brightness=0.4, contrast=0.4, saturation=0.3),
            transforms.RandomRotation(30),
            transforms.ToTensor(),
            AddGaussianNoise(std=0.10),
            AddBlur(kernel_size=5),
            transforms.Normalize(mean=IMAGENET_MEAN, std=IMAGENET_STD),
        ]),
    }
    return noise_transforms.get(noise_type, noise_transforms["gaussian"])

def plot_history(history: dict, title: str = ""):
    """Plot training loss, accuracy, and learning rate curves."""
    fig, axes = plt.subplots(1, 3, figsize=(20, 5))

    epochs_range = range(1, len(history["train_loss"]) + 1)

    # Loss
    axes[0].plot(epochs_range, history["train_loss"], "o-", label="Train", linewidth=2)
    axes[0].plot(epochs_range, history["val_loss"],   "s-", label="Val",   linewidth=2)
    axes[0].set_title("Loss", fontsize=13)
    axes[0].set_xlabel("Epoch")
    axes[0].legend()
    axes[0].grid(True, alpha=0.3)

    # Accuracy
    axes[1].plot(epochs_range, history["train_acc"], "o-", label="Train", linewidth=2)
    axes[1].plot(epochs_range, history["val_acc"],   "s-", label="Val",   linewidth=2)
    axes[1].set_title("Accuracy", fontsize=13)
    axes[1].set_xlabel("Epoch")
    axes[1].legend()
    axes[1].grid(True, alpha=0.3)

    # LR
    axes[2].plot(epochs_range, history["lr"], "d-", color="green", linewidth=2)
    axes[2].set_title("Learning Rate", fontsize=13)
    axes[2].set_xlabel("Epoch")
    axes[2].set_yscale("log")
    axes[2].grid(True, alpha=0.3)

    fig.suptitle(title, fontsize=15, y=1.03)
    plt.tight_layout()
    plt.show()


def plot_confusion_matrix(y_true, y_pred, class_names, title="", max_classes=25):
    """Plot confusion matrix (cap display to avoid enormous figures)."""
    cm = confusion_matrix(y_true, y_pred)
    n = min(len(class_names), max_classes)
    fig, ax = plt.subplots(figsize=(max(12, n * 0.45), max(10, n * 0.4)))
    sns.heatmap(
        cm[:n, :n], annot=(n <= 20), fmt="d", cmap="Blues",
        xticklabels=class_names[:n], yticklabels=class_names[:n], ax=ax
    )
    ax.set_xlabel("Predicted", fontsize=12)
    ax.set_ylabel("True", fontsize=12)
    ax.set_title(title, fontsize=14)
    plt.xticks(rotation=90, fontsize=7)
    plt.yticks(rotation=0, fontsize=7)
    plt.tight_layout()
    plt.show()



# 2. Locate the images automatically
def find_image_root(base: Path) -> Path:
    exts = {'.jpg', '.jpeg', '.png', '.bmp', '.gif', '.tiff'}
    for dirpath, _, filenames in os.walk(base):
        for f in filenames:
            if Path(f).suffix.lower() in exts:
                # Return the parent folder (which holds all class folders)
                return Path(dirpath).parent
    raise FileNotFoundError("Could not find any images.")

